{
    "name": "mage2kishan/module-crosslinks",
    "description": "Automatic internal crosslinks for Magento 2 (Hyva + Luma). Converts configured keywords in product, category, and CMS content into anchor links to boost internal linking and SEO. Extracted from Panth_AdvancedSEO for independent installation.",
    "type": "magento2-module",
    "version": "1.0.5",
    "license": "proprietary",
    "keywords": [
        "magento2",
        "magento2-module",
        "panth",
        "crosslinks",
        "internal-linking",
        "hyva",
        "luma",
        "seo"
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0",
        "magento/framework": "^103.0",
        "magento/module-backend": "^102.0",
        "magento/module-store": "^101.0",
        "magento/module-catalog": "^104.0",
        "magento/module-cms": "^104.0",
        "magento/module-ui": "^101.0",
        "mage2kishan/module-core": "^1.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Panth\\Crosslinks\\": ""
        }
    }
}
