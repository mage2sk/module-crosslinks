<?xml version="1.0"?>
<!--
/**
 * Panth Crosslinks — ACL
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Panth_Core::panth_extensions">
                    <resource id="Panth_Crosslinks::manage"
                              title="Crosslinks"
                              sortOrder="40">
                        <resource id="Panth_Crosslinks::crosslinks"
                                  title="Manage Crosslinks"
                                  sortOrder="10"/>
                        <resource id="Panth_Crosslinks::config"
                                  title="Configuration"
                                  sortOrder="20"/>
                    </resource>
                </resource>

                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Panth_Crosslinks::config"
                                      title="Panth Crosslinks Configuration"
                                      sortOrder="320"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
