<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <!-- Tab `panth` is declared by Panth_Core -->
        <section id="panth_crosslinks" translate="label" type="text" sortOrder="55" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Crosslinks</label>
            <tab>panth</tab>
            <resource>Panth_Crosslinks::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Auto Cross-Links</label>
                <field id="crosslinks_enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Auto Cross-Links</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Automatically converts configured keywords in CMS/product/category descriptions into internal links. Requires crosslink rules to be defined first.</comment>
                </field>
                <field id="max_links_per_page" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Links per Page</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Maximum number of auto-crosslinks injected per page to avoid over-optimization.</comment>
                    <depends>
                        <field id="crosslinks_enabled">1</field>
                    </depends>
                </field>
                <field id="excluded_tags" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Excluded Tags (comma-separated)</label>
                    <comment>HTML tags where keywords should not be linked (e.g. h1,h2,h3,h4,h5,h6,a,button,script,style).</comment>
                    <depends>
                        <field id="crosslinks_enabled">1</field>
                    </depends>
                </field>
                <field id="crosslink_time_activation" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Time-Based Activation</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When enabled, crosslinks respect Active From / Active To date fields on each rule.</comment>
                    <depends>
                        <field id="crosslinks_enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
