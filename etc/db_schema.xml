<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- ============================================================ -->
    <!-- panth_seo_crosslink                                            -->
    <!-- NOTE: Table name kept as `panth_seo_crosslink` (not renamed to  -->
    <!-- `panth_crosslink`) so that crosslink rules created under       -->
    <!-- Panth_AdvancedSEO continue to work unchanged after this module -->
    <!-- takes over ownership. See CHANGELOG.md.                        -->
    <!-- ============================================================ -->
    <table name="panth_seo_crosslink" resource="default" engine="innodb" comment="Panth Auto Cross-Links">
        <column xsi:type="int" name="crosslink_id" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="varchar" name="keyword" length="255" nullable="false"/>
        <column xsi:type="varchar" name="url" length="512" nullable="false"/>
        <column xsi:type="varchar" name="url_title" length="255" nullable="true"/>
        <column xsi:type="smallint" name="max_replacements" unsigned="true" nullable="false" default="1"/>
        <column xsi:type="boolean" name="nofollow" nullable="false" default="false"/>
        <column xsi:type="int" name="priority" unsigned="true" nullable="false" default="0"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true"/>
        <column xsi:type="boolean" name="in_product" nullable="false" default="true"/>
        <column xsi:type="boolean" name="in_category" nullable="false" default="true"/>
        <column xsi:type="boolean" name="in_cms" nullable="false" default="true"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" default="0"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP"/>
        <column xsi:type="timestamp" name="active_from" on_update="false" nullable="true" comment="Crosslink active from"/>
        <column xsi:type="timestamp" name="active_to" on_update="false" nullable="true" comment="Crosslink active until"/>
        <column xsi:type="varchar" name="reference_type" length="32" nullable="false" default="url" comment="Reference type: url|product_sku|category_id"/>
        <column xsi:type="varchar" name="reference_value" length="255" nullable="true" comment="Reference value (SKU or category ID)"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="crosslink_id"/>
        </constraint>
        <index referenceId="PANTH_SEO_CROSSLINK_IDX_ACTIVE_STORE">
            <column name="is_active"/>
            <column name="store_id"/>
        </index>
    </table>
</schema>
