<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_crosslink_form.panth_crosslink_form_data_source</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="delete" class="Panth\Crosslinks\Block\Adminhtml\GenericDeleteButton"/>
            <button name="save_and_continue" class="Panth\Crosslinks\Block\Adminhtml\GenericSaveAndContinueButton"/>
            <button name="save" class="Panth\Crosslinks\Block\Adminhtml\GenericSaveButton"/>
            <button name="back" class="Panth\Crosslinks\Block\Adminhtml\GenericBackButton"/>
        </buttons>
        <namespace>panth_crosslink_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>panth_crosslink_form.panth_crosslink_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="panth_crosslink_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="panth_crosslinks/crosslink/save"/>
        </settings>
        <dataProvider class="Panth\Crosslinks\Ui\Component\Form\DataProvider\CrosslinkFormDataProvider" name="panth_crosslink_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>crosslink_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">General</label>
        </settings>
        <field name="crosslink_id" formElement="input">
            <settings>
                <visible>false</visible>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="keyword" sortOrder="10" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Keyword</label>
                <dataScope>keyword</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">The keyword or phrase to find and link. Case-insensitive, whole-word match.</notice>
            </settings>
        </field>
        <field name="reference_type" sortOrder="15" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Reference Type</label>
                <dataScope>reference_type</dataScope>
                <switcherConfig>
                    <rules>
                        <rule name="0">
                            <value>url</value>
                            <actions>
                                <action name="0">
                                    <target>panth_crosslink_form.panth_crosslink_form.general.url</target>
                                    <callback>show</callback>
                                </action>
                                <action name="1">
                                    <target>panth_crosslink_form.panth_crosslink_form.general.reference_value</target>
                                    <callback>hide</callback>
                                </action>
                            </actions>
                        </rule>
                        <rule name="1">
                            <value>product_sku</value>
                            <actions>
                                <action name="0">
                                    <target>panth_crosslink_form.panth_crosslink_form.general.url</target>
                                    <callback>hide</callback>
                                </action>
                                <action name="1">
                                    <target>panth_crosslink_form.panth_crosslink_form.general.reference_value</target>
                                    <callback>show</callback>
                                </action>
                            </actions>
                        </rule>
                        <rule name="2">
                            <value>category_id</value>
                            <actions>
                                <action name="0">
                                    <target>panth_crosslink_form.panth_crosslink_form.general.url</target>
                                    <callback>hide</callback>
                                </action>
                                <action name="1">
                                    <target>panth_crosslink_form.panth_crosslink_form.general.reference_value</target>
                                    <callback>show</callback>
                                </action>
                            </actions>
                        </rule>
                    </rules>
                    <enabled>true</enabled>
                </switcherConfig>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Panth\Crosslinks\Model\Config\Source\CrosslinkReferenceType"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="url" sortOrder="20" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">URL</label>
                <dataScope>url</dataScope>
                <notice translate="true">The destination URL for the crosslink (e.g. /category/shoes.html or https://example.com/page).</notice>
            </settings>
        </field>
        <field name="reference_value" sortOrder="22" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Reference Value</label>
                <dataScope>reference_value</dataScope>
                <visible>false</visible>
                <notice translate="true">Product SKU or Category ID depending on reference type.</notice>
            </settings>
        </field>
        <field name="url_title" sortOrder="30" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">URL Title</label>
                <dataScope>url_title</dataScope>
                <notice translate="true">Optional title attribute for the anchor tag (tooltip text).</notice>
            </settings>
        </field>
        <field name="store_id" sortOrder="40" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Store View</label>
                <dataScope>store_id</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Store\Model\System\Store"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="is_active" sortOrder="50" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="active_from" sortOrder="60" formElement="date">
            <settings>
                <dataType>date</dataType>
                <label translate="true">Active From</label>
                <dataScope>active_from</dataScope>
                <notice translate="true">Optional. If set, the crosslink will only be active from this date onwards.</notice>
            </settings>
        </field>
        <field name="active_to" sortOrder="70" formElement="date">
            <settings>
                <dataType>date</dataType>
                <label translate="true">Active To</label>
                <dataScope>active_to</dataScope>
                <notice translate="true">Optional. If set, the crosslink will be deactivated after this date.</notice>
            </settings>
        </field>
    </fieldset>
    <fieldset name="placement">
        <settings>
            <label translate="true">Placement</label>
        </settings>
        <field name="in_product" sortOrder="10" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Apply to Products</label>
                <dataScope>in_product</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="in_category" sortOrder="20" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Apply to Categories</label>
                <dataScope>in_category</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="in_cms" sortOrder="30" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Apply to CMS Pages</label>
                <dataScope>in_cms</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="max_replacements" sortOrder="40" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Max Replacements</label>
                <dataScope>max_replacements</dataScope>
                <validation>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                    <rule name="validate-greater-than-zero" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">Maximum number of times this keyword will be linked per page. Default: 1.</notice>
            </settings>
        </field>
        <field name="nofollow" sortOrder="50" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Nofollow</label>
                <dataScope>nofollow</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="priority" sortOrder="60" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Priority</label>
                <dataScope>priority</dataScope>
                <validation>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">Higher numbers are processed first. Default: 0.</notice>
            </settings>
        </field>
    </fieldset>
</form>
